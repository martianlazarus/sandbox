  <script>
    function openReportModal() {
      const modal = new bootstrap.Modal(document.getElementById('reportModal'));
      modal.show();
    }

    function submitReport() {
      const filecode = document.getElementById('reportFilecode').value;
      const reason = document.getElementById('reportReason').value;
      const details = document.getElementById('reportDetails').value;
      const messageDiv = document.getElementById('reportMessage');

      if (!reason) {
        messageDiv.className = 'alert alert-warning';
        messageDiv.textContent = 'Please select a reason for reporting';
        messageDiv.classList.remove('d-none');
        return;
      }

      
      fetch('/api/report', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          filecode: filecode,
          reason: reason,
          details: details
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          messageDiv.className = 'alert alert-success';
          messageDiv.textContent = 'Report submitted successfully. Thank you!';
          messageDiv.classList.remove('d-none');
          
          document.getElementById('reportReason').value = '';
          document.getElementById('reportDetails').value = '';
          
          setTimeout(() => {
            bootstrap.Modal.getInstance(document.getElementById('reportModal')).hide();
            messageDiv.classList.add('d-none');
          }, 2000);
        } else {
          messageDiv.className = 'alert alert-danger';
          messageDiv.textContent = 'Error: ' + (data.error || 'Failed to submit report');
          messageDiv.classList.remove('d-none');
        }
      })
      .catch(error => {
        messageDiv.className = 'alert alert-danger';
        messageDiv.textContent = 'Network error: ' + error;
        messageDiv.classList.remove('d-none');
      });
    }
  </script>

